# Optional: override default ws://localhost:9001/mqtt (embedded bitstream broker WebSockets)
# VITE_MQTT_WS_URL=ws://192.168.1.10:9001/mqtt

# Overrides UI default `tesaiot/sensors` — must match firmware MQTT_BASE_TOPIC for <prefix>/env, imu, mag
# VITE_MQTT_BASE_TOPIC=tesaiot/sensors

# Optional: MQTT CONNECT client id in the browser (empty in UI = random web-… each connect)
# VITE_MQTT_CLIENT_ID=tesaiot-dashboard-1

# JSONViewer theme: dark | light | nord | vscode | basic | monokai | gruvbox | githubLight | githubDark
# VITE_JSON_VIEWER_THEME=nord

# services-tools HTTP API (bitstream serve). The UI always requests GET /api/v1/mqtt-config/client
# on load (same data as mqtt_client_config.snapshot.json) unless you disable it below.
# Default base URL is http://127.0.0.1:8787 — override if bitstream serve uses another host/port:
# VITE_BITSTREAM_API_URL=http://127.0.0.1:8787
# To skip the request entirely, set to empty:
# VITE_BITSTREAM_API_URL=
